# Copy to .env.local for local development with `vercel dev`.
# In production, set these in the Vercel dashboard (Settings -> Environment Variables).

# Required for coin identification.
ANTHROPIC_API_KEY=your_api_key_here

# Login (optional). Set BOTH to turn on the password gate. Leave unset to run the
# app open (no login). APP_PASSWORD is the shared password; AUTH_SECRET signs the
# session cookie — use a long random string, e.g. `openssl rand -hex 32`.
APP_PASSWORD=choose_a_password
AUTH_SECRET=long_random_string

# Collection persistence (optional). Provision a Redis/KV store in the Vercel
# dashboard (Storage tab) and connect it to the project — these are injected
# automatically. Without them, the collection falls back to per-browser
# localStorage. Either naming pair works:
# KV_REST_API_URL / KV_REST_API_TOKEN
# UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
